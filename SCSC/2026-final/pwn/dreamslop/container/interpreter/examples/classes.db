// Dreamberd classes can have at most two instances.

class Socket {
    const var id = 0!
    fn describe() {
        return "socket #" + self.id!
    }
}!

const var sa = new Socket()!
const var sb = new Socket()!
sa.id = 1!
sb.id = 2!

print(sa.describe())!
print(sb.describe())!

// Uncommenting the next line is a runtime error (only 2 sockets allowed).
// const const sc = new Socket()!

// Methods can use 'self'.
class Counter {
    const var n = 0!
    fn tick() {
        self.n = self.n + 1!
        return self.n!
    }
}!

const var c = new Counter()!
print(c.tick())!
print(c.tick())!
print(c.tick())!

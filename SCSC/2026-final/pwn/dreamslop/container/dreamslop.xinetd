service dreamslop
{
    disable         = no
    type            = UNLISTED
    socket_type     = stream
    protocol        = tcp
    wait            = no
    user            = ctf
    bind            = 0.0.0.0
    port            = 1337
    server          = /home/ctf/run.sh
    per_source      = 10
    rlimit_cpu      = 60
    flags           = REUSE
    log_on_success  += PID HOST DURATION
    log_on_failure  += HOST
}

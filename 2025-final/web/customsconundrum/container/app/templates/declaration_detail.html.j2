{% extends "base.html.j2" %}

{% block title %}Declaration Details - Advanced Customs Declaration System{% endblock %}

{% block content %}
<div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold text-customs-primary">Declaration Details</h1>
    <a href="/declarations" class="text-customs-accent hover:underline flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24"
            stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to All Declarations
    </a>
</div>

<div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="p-6">
        <div class="flex justify-between items-start">
            <div>
                <h2 class="text-xl font-bold text-gray-800" id="item_name">{{ declaration.item_name }}</h2>
                <p class="text-sm text-gray-500" id="id">{{ declaration.uuid }}</p>
            </div>
            <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full 
                {% if declaration.status == 'approved' %}
                    bg-green-100 text-green-800
                {% elif declaration.status == 'pending' %}
                    bg-yellow-100 text-yellow-800
                {% else %}
                    bg-red-100 text-red-800
                {% endif %}" id="status">
                {{ declaration.status|capitalize }}
            </span>
        </div>

        <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <h3 class="text-sm font-medium text-gray-500">Entry Date</h3>
                <p class="mt-1 text-sm text-gray-900" id="entry_date">{{ declaration.entry_date }}</p>
            </div>

            <div>
                <h3 class="text-sm font-medium text-gray-500">Declaration Date</h3>
                <p class="mt-1 text-sm text-gray-900" id="created_at">{{ declaration.created_at }}</p>
            </div>

            <div>
                <h3 class="text-sm font-medium text-gray-500">Country of Origin</h3>
                <p class="mt-1 text-sm text-gray-900" id="country">{{ declaration.country_origin }}</p>
            </div>

            <div>
                <h3 class="text-sm font-medium text-gray-500">Category</h3>
                <p class="mt-1 text-sm text-gray-900" id="category">{{ declaration.category|capitalize }}</p>
            </div>

            <div>
                <h3 class="text-sm font-medium text-gray-500">Quantity</h3>
                <p class="mt-1 text-sm text-gray-900" id="quantity">{{ declaration.quantity }}</p>
            </div>

            <div>
                <h3 class="text-sm font-medium text-gray-500">Value</h3>
                <p class="mt-1 text-sm text-gray-900" id="value">${{ declaration.value }}</p>
            </div>
        </div>

        <div class="mt-6">
            <h3 class="text-sm font-medium text-gray-500">Description</h3>
            <div class="mt-1 text-sm text-gray-900" id="description">
                {{ declaration.description | safe }}
            </div>
        </div>
    </div>
    <style>
    /* Styling for Markdown */
    #description h1 {
        font-size: 3rem;
        line-height: normal;
    }
    #description h2 {
        font-size: 2rem;
        line-height: normal;
    }
    #description h3 {
        font-size: 1.5rem;
        line-height: normal;
    }
    #description a {
        color: #2563EB;
    }
    </style>
</div>
{% endblock %}
{% extends "base.html.j2" %}

{% block title %}Error - Customs Administration{% endblock %}

{% block content %}
<div class="flex flex-col items-center justify-center py-10">
    <div class="bg-white p-8 rounded-lg shadow-md text-center w-full max-w-lg">
        <div class="mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-red-500" fill="none"
                viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <h2 class="text-2xl font-bold text-red-600 mb-4">Error</h2>
        <p class="text-gray-600 mb-6">{{ error }}</p>
        <a href="/admin/dashboard"
            class="inline-flex items-center bg-customs-primary text-white py-2 px-4 rounded-md hover:bg-opacity-90 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24"
                stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Return to Dashboard
        </a>
    </div>
</div>
{% endblock %}
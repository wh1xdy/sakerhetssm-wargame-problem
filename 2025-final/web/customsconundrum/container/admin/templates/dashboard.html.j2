{% extends "base.html.j2" %}

{% block title %}Dashboard - Customs Administration{% endblock %}

{% block content %}
<div class="mb-6 flex justify-between items-center">
    <h2 class="text-2xl font-bold text-customs-primary">All Customs Declarations</h2>
</div>

{% if error %}
<div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
    <span class="block sm:inline">{{ error }}</span>
</div>
{% endif %}

{% if declarations|length > 0 %}
<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Item</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Origin</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Value</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            {% for decl in declarations %}
            <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ decl.id }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ decl.entry_date }}</td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">{{ decl.item_name }}</div>
                    <div class="text-sm text-gray-500">{{ decl.category }}</div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ decl.country_origin }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${{ decl.value }}</td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                {% if decl.status == 'approved' %}
                    bg-green-100 text-green-800
                {% elif decl.status == 'rejected' %}
                    bg-red-100 text-red-800
                {% else %}
                    bg-yellow-100 text-yellow-800
                {% endif %}">
                        {{ decl.status|capitalize }}
                    </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a href="/admin/declarations/{{ decl.uuid }}"
                        class="text-customs-accent hover:text-opacity-75 mr-3">View</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div class="bg-white p-8 rounded-lg shadow-md text-center">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-gray-400 mb-4" fill="none" viewBox="0 0 24 24"
        stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    <h2 class="text-xl font-semibold mb-2">No declarations found</h2>
    <p class="text-gray-600 mb-6">There are no customs declarations in the system yet.</p>
</div>
{% endif %}
{% endblock %}
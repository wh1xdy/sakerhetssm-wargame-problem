{% extends "base.html.j2" %}

{% block title %}Declaration - Customs Administration{% endblock %}

{% block content %}
<div class="mb-6 flex justify-between items-center">
    <h2 class="text-2xl font-bold text-customs-primary">Declaration Details</h2>
    <a href="/admin/dashboard"
        class="bg-gray-200 text-gray-700 py-2 px-4 rounded-md hover:bg-gray-300 transition flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24"
            stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Dashboard
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="border-b pb-4 mb-4">
                <h3 class="text-xl font-semibold text-customs-primary">Declaration #{{ declaration.id }}</h3>
                <p class="text-xs text-gray-700">{{ declaration.uuid }}</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div>
                    <p class="mb-2"><span class="font-medium text-gray-700">Entry Date:</span> {{ declaration.entry_date
                        }}</p>
                    <p class="mb-2"><span class="font-medium text-gray-700">Item Name:</span> {{ declaration.item_name
                        }}</p>
                    <p class="mb-2"><span class="font-medium text-gray-700">Country of Origin:</span> {{
                        declaration.country_origin }}</p>
                    <p class="mb-2"><span class="font-medium text-gray-700">Category:</span> {{ declaration.category }}
                    </p>
                </div>
                <div>
                    <p class="mb-2"><span class="font-medium text-gray-700">Quantity:</span> {{ declaration.quantity }}
                    </p>
                    <p class="mb-2"><span class="font-medium text-gray-700">Value:</span> ${{ declaration.value }}</p>
                    <p class="mb-2"><span class="font-medium text-gray-700">Owner ID:</span> {{ declaration.owner_id }}
                    </p>
                    <p class="mb-2">
                        <span class="font-medium text-gray-700">Status:</span>
                        <span class="ml-1 px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
              {% if declaration.status == 'approved' %}
                  bg-green-100 text-green-800
              {% elif declaration.status == 'rejected' %}
                  bg-red-100 text-red-800
              {% else %}
                  bg-yellow-100 text-yellow-800
              {% endif %}">
                            {{ declaration.status|capitalize }}
                        </span>
                    </p>
                </div>
            </div>
            <div class="border-t pt-4">
                <h4 class="font-medium text-gray-700 mb-2">Description:</h4>
                <p class="text-gray-600">{{ declaration.description | safe}}</p>
            </div>
        </div>
    </div>

    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-md p-6">
            <h3 class="text-lg font-semibold border-b pb-3 mb-4 text-customs-primary">Actions</h3>
            <form method="POST" action="/admin/declarations/{{ declaration.uuid }}/status">
                <div class="mb-4">
                    <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Update Status</label>
                    <select id="status" name="status" class="w-full border border-gray-300 rounded-md">
                        <option value="pending" {% if declaration.status=='pending' %}selected{% endif %}>Pending
                        </option>
                        <option value="approved" {% if declaration.status=='approved' %}selected{% endif %}>Approved
                        </option>
                        <option value="rejected" {% if declaration.status=='rejected' %}selected{% endif %}>Rejected
                        </option>
                    </select>
                </div>
                <button type="submit"
                    class="w-full bg-customs-primary text-white py-2 px-4 rounded-md hover:bg-opacity-90 transition">
                    Update Status
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}